from 

def extract_title(markdown):
    lines = markdown.split("\n")
    for line in lines:
        if line.startswith("# "):
            return line[2:].strip()
    raise Exception("No h1 header found")

def generate_page(from_path, template_path, dest_path):
    file = open(from_path)
    contents = file.read()
    file.close()

    file = open(template_path)
    template = file.read()
    file.close()
